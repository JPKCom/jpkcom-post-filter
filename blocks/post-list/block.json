{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jpkcom/post-list",
	"version": "1.0.0",
	"title": "Post List",
	"category": "widgets",
	"icon": "list-view",
	"description": "Displays a filtered list of posts, pages, or custom post types.",
	"keywords": [ "posts", "list", "cards", "grid", "query" ],
	"textdomain": "jpkcom-post-filter",
	"attributes": {
		"postType": {
			"type": "string",
			"default": "post"
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"limit": {
			"type": "number",
			"default": 5
		},
		"orderby": {
			"type": "string",
			"default": "date"
		},
		"order": {
			"type": "string",
			"default": "DESC"
		},
		"className": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"className": true
	},
	"editorScript": "file:../build/post-list.js",
	"editorStyle": "file:../../assets/css/editor.css"
}
