{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jpkcom/post-pagination",
	"version": "1.0.0",
	"title": "Post Pagination",
	"category": "widgets",
	"icon": "controls-forward",
	"description": "Displays pagination for a filtered post list.",
	"keywords": [ "pagination", "paging", "navigation" ],
	"textdomain": "jpkcom-post-filter",
	"attributes": {
		"postType": {
			"type": "string",
			"default": "post"
		},
		"className": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"className": true
	},
	"editorScript": "file:../build/post-pagination.js",
	"editorStyle": "file:../../assets/css/editor.css"
}
